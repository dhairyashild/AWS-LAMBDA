import os

def lambda_handler(event, context):

    my_variable = os.environ.get('VARIABLE', 'default_value')                  #  os.environ.get()          to avoid KeyErrors 
    print(f"Retrieved variable value: {my_variable}")
    
    return {
        'statusCode': 200,
        'body': f"The variable value is: {my_variable}"
    }

