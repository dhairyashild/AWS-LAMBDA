#!/bin/bash
# YOUR BEST UV Lambda Deploy - Prod Ready

mkdir lambda-app && cd lambda-app                       # 1. Create project dir

uv init                                              # 2. Init pyproject.toml

echo 'requests = "*" 
boto3 = "*"' >> pyproject.toml

cat > app.py << 'EOF'                                                            # 4. Create handler
def lambda_handler(event, context):
    return {"statusCode": 200, "body": "Hello!"}
EOF

uv sync --frozen                                      # 5. Install deps

rm -rf .venv                                             # 6. Clean
uv pip install --target . -r <(uv export --format requirements --no-dev) --platform linux_x86_64        # 7. Linux deps

zip -r ../func.zip app.py . -x "*.git* *.venv* pyproject.toml *.pyc"                                 # 8. Zip clean

aws lambda create-function --function-name my-func --runtime python3.12 --role arn:aws:iam::ACCOUNT:role/lambda-role --handler app.lambda_handler --zip-file fileb://../func.zip  # 9. Deploy
